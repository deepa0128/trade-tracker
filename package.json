{
  "name": "trade-tracker",
  "version": "1.0.0",
  "description": "BSE/NSE portfolio tracker with pluggable data providers, JWT auth, and PostgreSQL",
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file=.env watch src/server.ts",
    "start": "tsx --env-file=.env src/server.ts",
    "migrate": "tsx scripts/migrate.ts",
    "seed-db": "tsx scripts/seed-db.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "export-portfolios": "tsx scripts/export-portfolios.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "bcryptjs": "^2.4.3",
    "fastify": "^4.28.0",
    "jsonwebtoken": "^9.0.2",
    "postgres": "^3.4.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.5",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
