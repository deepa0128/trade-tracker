# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# ── Database (PostgreSQL) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trade_tracker
DB_USER=postgres
DB_PASSWORD=postgres

# ── Auth (JWT) ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=change_me_in_production_use_openssl_rand_hex_64
JWT_USER_EXPIRY=7d
JWT_GUEST_EXPIRY=24h

# ── Market Data Provider ─────────────────────────────────────────────────────
# 'mock' | 'yfinance' | 'fmp'
MARKET_DATA_PROVIDER=mock

# Required when MARKET_DATA_PROVIDER=fmp
FMP_API_KEY=

# Python binary used by YFinanceProvider subprocess call
PYTHON_BIN=python3

# Timeout for external provider calls (ms)
PROVIDER_TIMEOUT_MS=10000
PROVIDER_RETRIES=2
